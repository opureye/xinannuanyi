# OpenAI API配置示例
# 复制此文件为.env并填入实际配置

# OpenAI API密钥 (必需)
OPENAI_API_KEY=sk-ZnDXAGsyFG0OoTJs3DflsMLMBvogyeXmz78SvemEEjlBTNkI

# 自定义API端点 (可选，用于兼容OpenAI格式的其他服务)
OPENAI_BASE_URL=https://tbnx.plus7.plus/v1

# 使用的模型名称 (可选)
OPENAI_MODEL=deepseek-reasoner

# 使用说明：
# 1. 将此文件复制为.env
# 2. 填入您的实际API密钥
# 3. 如需使用其他AI服务(如Azure OpenAI、Claude等)，修改相应配置
# 4. 运行程序前确保已安装openai库: pip install openai