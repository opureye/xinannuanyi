# —— 腾讯云实名认证配置 ——
# 开启腾讯云实名核验（true/false）
ENABLE_TENCENT_IDENTITY_VERIFY=false

# 腾讯云凭证（示例占位，正式使用请替换为真实密钥）
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# 区域（可根据你的账号所在区域调整）
TENCENTCLOUD_REGION=ap-guangzhou

# —— AI 聊天配置 ——
# poloai.top API密钥（请替换为有效的API密钥）
POLOAI_API_KEY=
# API主机地址
POLOAI_HOST=https://poloai.top
# 默认模型
DEFAULT_MODEL=deepseek-v3.2

# 说明：
# 1) 当前后端实现在开关为 true 且 SECRET_ID/SECRET_KEY 非空时，走"腾讯云模式（模拟通过）"。
# 2) 若需要真实接入腾讯云接口，请将上面两项替换为真实密钥，并告知我以便接入正式API调用与签名。
# 3) POLOAI_API_KEY 需要替换为有效的 poloai.top API密钥才能使用AI聊天功能。
